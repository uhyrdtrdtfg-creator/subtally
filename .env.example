# App Store Connect API credentials for automated TestFlight upload.
# Copy this file to `.env` (gitignored) and fill in real values.
#
# Where to get these:
#   appstoreconnect.apple.com → Users and Access → Integrations tab → App Store Connect API
#   → Generate an API Key with role "App Manager" (or higher)
#   → Download the .p8 file ONCE (Apple will not let you download it again)
#   → Copy the Key ID (10 chars) and Issuer ID (UUID) from the Keys list
#
# Where to put the .p8 file:
#   mkdir -p ~/.appstoreconnect/private_keys
#   mv ~/Downloads/AuthKey_<KEY_ID>.p8 ~/.appstoreconnect/private_keys/
#
# The script will auto-detect it at that standard path; override via ASC_API_KEY_PATH
# if you keep it elsewhere.

ASC_KEY_ID=
ASC_ISSUER_ID=

# Optional override (default: ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8)
# ASC_API_KEY_PATH=
